.ace_print-margin { position: absolute; height: 100%; }

.ace_text-input { position: absolute; z-index: 0; width: 0.5em; height: 1em=
; opacity: 0; background: transparent; appearance: none; border-width: medi=
um; border-style: none; border-color: currentcolor; border-image: initial; =
resize: none; outline: none; overflow: hidden; font: inherit; padding: 0px =
1px; margin: 0px -1px; contain: strict; user-select: text; white-space: pre=
 !important; }

